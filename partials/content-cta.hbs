{{{html}}}
<aside class="gh-post-upgrade-cta">
    <div class="gh-post-upgrade-cta-content" style="background-color: {{@site.accent_color}}">
        {{#has visibility="paid"}}
            {{#is "page"}}
                <h2>This page (or the rest of this page) is for paying subscribers only</h2>
            {{else}}
                <h2>This post (or the rest of this post) is for paying subscribers only</h2>
            {{/is}}
            <p class="extra">You don't have access to this article at the moment, but if you <a href="#/portal/signup" data-portal="signup">sign up to a paid account</a> you'll be able to see the whole thing, as well as all the other articles! Subscribing only takes a few seconds and will give you immediate access.</p>
        {{/has}}
        {{#has visibility="members"}}
            {{#is "page"}}
                <h2>This page (or the rest of this page) is for subscribers only (free)</h2>
            {{else}}
                <h2>This post (or the rest of this post) is for subscribers only (free)</h2>
            {{/is}}
            <p class="extra"><a href="#/portal/signup" data-portal="signup">Sign up to a free account</a> to gain full access to this article, as well as all the other member articles! Subscribing only takes a few seconds, is free, and will give you immediate access.</p>
        {{/has}}
        {{#has visibility="tiers"}}
            {{#is "page"}}
                <h2>{{{t "This page is for subscribers on the {tiers} only" tiers=(tiers separator=", " lastSeparator=(t " and "))}}}</h2>
            {{else}}
                <h2>{{{t "This post is for subscribers on the {tiers} only" tiers=(tiers separator=", " lastSeparator=(t " and "))}}}</h2>
            {{/is}}
        {{/has}}
        {{#if @member}}
            <a class="gh-btn" data-portal="account/plans" href="#/portal/account/plans" style="color:{{@site.accent_color}}">{{t "Upgrade your account"}}</a>
        {{else}}
            <a class="gh-btn" data-portal="signup" href="#/portal/signup" style="color:{{@site.accent_color}}">{{t "Subscribe now"}}</a>
            <p><small>{{t "Already have an account?"}} <a data-portal="signin" href="#/portal/signin">{{t "Sign in"}}</a></small></p>
        {{/if}}
    </div>
</aside>
